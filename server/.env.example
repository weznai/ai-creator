# 应用配置
NODE_ENV=development
PORT=3000
APP_NAME=ai-creator

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=ai_creator

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=2h

# AI服务配置
OPENAI_API_KEY=
DASHSCOPE_API_KEY=

# 存储配置
STORAGE_TYPE=local
STORAGE_PATH=./uploads
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_REGION=
OSS_ENDPOINT=
